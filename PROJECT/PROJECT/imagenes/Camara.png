        padding-top: 8px;
    }

    .ais-FrequentlyBoughtTogether-title,
    .ais-RelatedProducts-title,
    .ais-TrendingItems-title,
    .ais-LookingSimilar-title {
        display: none;
    }


    .link-carousel {
        display: flex;
        flex-direction: column;
        height: 100%;
        /* Muy importante: que todas tengan el mismo alto */
    }

    a.link-carousel:hover {
        text-decoration: none;
    }

    .ais-Carousel-navigation svg {
        display: none;
    }

    .ais-Carousel-navigation {
        color: white;
        opacity: 1;
        visibility: visible;
        background: var(--primary-color2);
        width: 24px;
        height: 24px;
        border-radius: 50%;
        transition: background 0.3s, color 0.3s;
        top: -34px;
    }

    .ais-Carousel-navigation:focus {
        background: var(--primary-color2);
        box-shadow: none;
    }

    .ais-Carousel-navigation--previous {
        right: 12px;
        transform: translateX(-100%);
        left: initial;
    }

    .ais-Carousel-navigation--previous::before {
        content: "\e9b4";
        font-family: alk-icon !important;
        font-size: 16px;
        color: white;
        display: flex;
        align-items: center;
        justify-content: center;
    }


    .ais-Carousel-navigation--next {
        transform: translateX(-25%);
    }

    .ais-Carousel-navigation--next::before {
        content: "\e9b5";
        font-family: alk-icon !important;
        font-size: 16px;
        color: white;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .ais-Carousel-navigation:hover::before {
        color: white;
        opacity: 1;
        visibility: visible;
        background: var(--primary-color2);
        width: 24px;
        height: 24px;
        border-radius: 50%;
    }

    .ais-Carousel-navigation:active {
        box-shadow: none;
    }


    .ais-Carousel-list {
        overflow-x: auto;
        display: grid;
        grid-auto-flow: column;
        padding-top: 4px;
        padding-bottom: 16px;
        scroll-padding-left: 32px;
        gap: 12px;
        scroll-snap-type: x mandatory;
        scrollbar-color: var(--grey-light);

    }

    .ais-Carousel-item {
        display: block;
        padding: 16px;
        scroll-snap-align: start;
    }

    .ais-Carousel-item:first-child {
        margin-left: 12px;
    }

    .ais-RelatedProducts-item {
        font-size: 14px;
        border-radius: 4px;
        background: #FFF;
        box-shadow: 0px 0px 4px 0px rgba(145, 155, 166, 0.40);
    }

    .yellow-stars .averageNumber {
        color: var(--text-color2);
