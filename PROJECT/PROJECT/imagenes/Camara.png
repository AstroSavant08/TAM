        -webkit-box-align: center;
        -ms-flex-align: center;
        align-items: center;
    }

    .price__old-price {
        margin-bottom: 8px;
        display: flex;
        align-items: center;
    }

    .span_price__old-price {
        color: var(--grey-light);
        font-size: 16px;
        text-decoration: line-through;
        margin: 0;
    }

    .price__discount-label {
        display: -ms-flexbox;
        display: -ms-flex;
        display: -webkit-box;
        display: flex;
        position: relative;
        left: unset;
        top: unset;
        right: unset;
        text-decoration: initial;
    }

    .price__discount-label .label-offer {
