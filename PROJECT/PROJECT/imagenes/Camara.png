	.container-2 {
		width: 100%;
		max-width: 1366px;
		margin: 0 auto;
		padding: 0;
	}

	/* sección 01 */

	.section-enrichment-one {
		display: flex;
		flex-direction: row;
		justify-content: space-between;
		align-items: center;
		gap: 1em;
		padding: 2em 4em;
		margin-bottom: 4em;
	}

	.bg-gray {
		background-color: #F5F5F5;
	}

	.section-enrichment-one .hero-text {
		width: 40%;
	}

	.hero-text h1 span:first-child {
		display: block;
		font-size: 50px;
	}

	.hero-text h1 {
		font-size: 72px;
		line-height: 78px;
	}

	.hero-text p {
		width: 100%;
	}

	.section-enrichment-one img {
		width: 36%;
	}

	/* sección 02 */

	.section-enrichment-two {
		display: flex;
		flex-direction: row;
		justify-content: space-between;
		gap: 1em;
		padding: 4em;
		border-bottom: 1px solid #e0e0e070;
	}

	.section-enrichment-two .two-image {
		display: flex;
		flex-direction: row;
		gap: 4em;
		width: 50%;
	}

	.section-enrichment-two .two-image img:nth-child(1) {
		align-self: flex-start;
		margin-top: -4em;
	}

	.section-enrichment-two .two-image img:nth-child(2) {
		align-self: flex-end;
	}

	.section-enrichment-two .features-text {
		width: 50%;
		display: flex;
		flex-direction: column;
		gap: 4em;
	}

	.features-text h2 {
		font-size: 48px;
		line-height: 52px;
		align-self: flex-end;
		width: 80%;
		text-align: end;
	}

	.features-text p {
		text-align: right;
	}

	/* sección 03 */
	.section-enrichment-three {
		display: flex;
		flex-direction: row;
		justify-content: space-between;
		padding: 4em 4em 2em;
	}

	.section-enrichment-three .feature {
		display: flex;
		flex-direction: column;
		align-items: flex-start;
		width: calc(33% - 5em);
	}


	.section-enrichment-three .feature h3 {
		font-size: 18px;
		color: #707070;
	}

	.section-enrichment-three .feature p {
		font-size: 14px;
		color: #707070;
		text-align: left;
	}

	/* sección 04 */

	.section-enrichment-four {
		display: flex;
		flex-direction: row;
		justify-content: space-between;
		align-items: center;
		gap: 4em;
		padding: 2em 4em 0;
